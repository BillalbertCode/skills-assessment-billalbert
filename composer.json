{
    "name": "dustov/quotes",
    "description": "skill-assessment quotes",
    "type": "laravel-package",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Dustov\\Quotes\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "dustov\\quotes\\QuotesServiceProvider"
            ],
            "aliases": {
                "Quotes": "dustov\\quotes\\Facades\\Quotes"
            }
        }
    },
    "authors": [
        {
            "name": "billalbertcode",
            "email": "billalbertcode@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
